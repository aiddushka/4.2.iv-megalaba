# ---- MQTT ----
MQTT_BROKER_HOST=mqtt-broker
MQTT_BROKER_PORT=8883
MQTT_BROKER_PORT_BACKEND=8883
MQTT_BROKER_PORT_DEVICE=8883
MQTT_CLIENT_ID=greenhouse-backend
MQTT_TLS_ENABLED_BACKEND=true
MQTT_TLS_CA_CERT_BACKEND=/mqtt-certs/ca.crt
MQTT_TLS_INSECURE_BACKEND=false
MQTT_TLS_CLIENT_CERT_BACKEND=/mqtt-certs/backend_client.crt
MQTT_TLS_CLIENT_KEY_BACKEND=/mqtt-certs/backend_client.key
MQTT_TLS_ENABLED_DEVICE=true
MQTT_TLS_CA_CERT_DEVICE=/mqtt-certs/ca.crt
MQTT_TLS_INSECURE_DEVICE=false
MQTT_TLS_CLIENT_CERT_DEVICE=/mqtt-certs/device_client.crt
MQTT_TLS_CLIENT_KEY_DEVICE=/mqtt-certs/device_client.key
MQTT_SHARED_CERTS_VOLUME=greenhouse_mqtt_shared_certs
MQTT_USERNAME_BACKEND=backend_user
MQTT_PASSWORD_BACKEND=Br9xP2AkL7vQ4mN8tR1Y6u
MQTT_USERNAME_DEVICE=device_user
MQTT_PASSWORD_DEVICE=Dy4zT9qW2mK6pH8sL3nV5r
MQTT_SENSOR_TOPIC=greenhouse/sensors/+/data
MQTT_ACTUATOR_STATE_TOPIC=greenhouse/actuators/+/state
MQTT_HEARTBEAT_TOPIC=greenhouse/devices/+/heartbeat
MQTT_DEVICE_TOKEN_REJECT_LOG_INTERVAL=30
MQTT_MAX_PAYLOAD_BYTES=8192
MQTT_RATE_LIMIT_GLOBAL_PER_SEC=200
MQTT_RATE_LIMIT_PER_DEVICE_PER_SEC=10
MQTT_RATE_LIMIT_BURST=20
MQTT_REPLAY_WINDOW_SECONDS=30
MQTT_REPLAY_ID_TTL_SECONDS=120
HEARTBEAT_STALE_SECONDS=30

# ---- Sensor manager / runtime orchestration ----
BACKEND_URL=http://backend:8000
POLL_INTERVAL_SECONDS=5
HEALTHCHECK_INTERVAL_SECONDS=10
STATE_FILE_PATH=/state/state.json
RUNTIME_SECRETS_DIR=/runtime-secrets
DEVICE_RUNTIME_SECRETS_VOLUME=greenhouse_device_runtime_secrets
DEVICE_NETWORK_NAME=greenhouse_iot_net
DEVICE_IMAGE=docker-device-runtime
DEVICE_GROUP_PROJECT=devices
DEVICE_GROUP_SERVICE=device-runtime
SENSOR_IP_RANGE=172.28.1.10-172.28.1.250
ACTUATOR_IP_RANGE=172.28.2.10-172.28.2.250
